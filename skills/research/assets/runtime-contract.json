{
  "contract_version": "2.0",
  "state_schema_version": "2.0",
  "state": {
    "required_fields": [
      "schema_version",
      "workflow_version",
      "enabled",
      "project_id",
      "project_name",
      "current_stage",
      "lifecycle",
      "activation_history",
      "gates",
      "artifacts",
      "last_checkpoint",
      "stage_history",
      "created_at",
      "updated_at"
    ]
  },
  "decision": {
    "required_fields": [
      "decision_id",
      "action",
      "previous_status",
      "new_status",
      "reason",
      "actor",
      "decided_at",
      "artifact_refs",
      "supporting_evidence_ids",
      "opposing_evidence_ids",
      "unresolved_risks",
      "decision_conditions"
    ]
  },
  "lifecycle": {
    "statuses": ["active", "terminated", "completed"],
    "actions": ["terminate", "complete", "reopen"],
    "record_fields": ["status", "latest_decision_id", "history"],
    "decision_fields": ["stage"],
    "decision_optional_fields": ["gate_ref", "gate_decision_id"]
  },
  "activation": {
    "actions": ["enable", "disable"],
    "event_fields": [
      "action",
      "previous_enabled",
      "new_enabled",
      "reason",
      "actor",
      "decided_at"
    ]
  },
  "gate": {
    "statuses": ["pending", "approved", "reopened"],
    "actions": ["approve", "reopen"],
    "record_fields": ["status", "latest_decision_id", "history"],
    "target_container_fields": ["targets"],
    "decision_optional_fields": [
      "approval_mode",
      "waived_artifact_roles",
      "selection",
      "cascade"
    ],
    "cascade_fields": [
      "upstream_gate_ref",
      "upstream_decision_id",
      "upstream_reason"
    ],
    "gate_ref_required_fields": ["gate"],
    "gate_ref_optional_fields": ["target"],
    "selection_fields": ["selected_id", "artifact_ref"]
  },
  "artifact": {
    "entry_fields": ["current_revision", "revisions"],
    "revision_fields": [
      "revision",
      "source_path",
      "snapshot_path",
      "content_hash",
      "size_bytes",
      "registered_at"
    ],
    "reference_prefix_fields": ["label", "artifact_id"]
  },
  "checkpoint": {
    "fields": ["summary", "timestamp"]
  },
  "stage_transition": {
    "fields": ["from_stage", "to_stage", "trigger", "timestamp"],
    "trigger_prefixes": ["checkpoint", "gate-approve", "gate-reopen"]
  },
  "scientific_record": {
    "manifest_schema_version": "1.0",
    "artifact_role": "record_manifest",
    "manifest_fields": ["schema_version", "stage", "records"],
    "record_fields": [
      "record_id",
      "record_kind",
      "source",
      "supersedes",
      "relations"
    ],
    "source_fields": ["artifact_role", "artifact_id", "revision", "locator"],
    "relation_fields": ["relation", "target_id"],
    "record_kinds": [
      "candidate",
      "search_run",
      "passage_evidence",
      "experiment",
      "attempt",
      "analysis",
      "claim",
      "paper_location",
      "review_concern"
    ],
    "relation_kinds": [
      "derived_from",
      "discovered_by",
      "supports",
      "contradicts",
      "qualifies",
      "tests",
      "attempt_of",
      "analyzes",
      "expresses",
      "addresses"
    ],
    "relation_signatures": {
      "derived_from": {
        "source_kinds": ["candidate", "claim"],
        "target_kinds": ["candidate"]
      },
      "discovered_by": {
        "source_kinds": ["passage_evidence"],
        "target_kinds": ["search_run"]
      },
      "supports": {
        "source_kinds": ["passage_evidence", "analysis"],
        "target_kinds": ["candidate", "claim"]
      },
      "contradicts": {
        "source_kinds": ["passage_evidence", "analysis"],
        "target_kinds": ["candidate", "claim"]
      },
      "qualifies": {
        "source_kinds": ["passage_evidence", "analysis"],
        "target_kinds": ["candidate", "claim"]
      },
      "tests": {
        "source_kinds": ["experiment"],
        "target_kinds": ["candidate", "claim"]
      },
      "attempt_of": {
        "source_kinds": ["attempt"],
        "target_kinds": ["experiment"]
      },
      "analyzes": {
        "source_kinds": ["analysis"],
        "target_kinds": ["attempt", "experiment"]
      },
      "expresses": {
        "source_kinds": ["paper_location"],
        "target_kinds": ["claim"]
      },
      "addresses": {
        "source_kinds": ["paper_location"],
        "target_kinds": ["review_concern"]
      }
    }
  },
  "adapter_exchange": {
    "manifest_schema_version": "1.0",
    "protocol_version": "1.0",
    "artifact_role": "adapter_exchange",
    "manifest_fields": ["schema_version", "stage", "requests", "receipts"],
    "request_fields": [
      "request_id",
      "operation_kind",
      "created_at",
      "gate_binding",
      "payload",
      "input_artifact_refs",
      "effect_class",
      "human_authorization",
      "retry_policy"
    ],
    "payload_fields": ["artifact_ref", "locator"],
    "gate_binding_fields": ["gate_ref", "gate_decision_id", "artifact_refs"],
    "human_authorization_fields": [
      "authorization_id",
      "actor",
      "authorized_at",
      "scope"
    ],
    "retry_policy_fields": ["mode", "max_attempts", "idempotency_key"],
    "receipt_fields": [
      "receipt_id",
      "request_id",
      "request_hash",
      "attempt_id",
      "retry_of_attempt_id",
      "supersedes",
      "adapter",
      "status",
      "observed_at",
      "external_id",
      "output_artifact_refs",
      "log_artifact_refs",
      "message"
    ],
    "adapter_fields": ["adapter_id", "adapter_version", "protocol_version"],
    "verification_fields": [
      "schema_version",
      "verification",
      "verified_at",
      "request_hash",
      "attempt_id",
      "retry_of_attempt_id",
      "request"
    ],
    "operation_kinds": [
      "evidence_retrieval",
      "experiment_execution",
      "result_import",
      "paper_production",
      "external_release"
    ],
    "effect_classes": [
      "low_risk",
      "costly_compute",
      "destructive",
      "safety_relevant",
      "external_release"
    ],
    "retry_modes": ["never", "idempotent", "reconcile_before_retry"],
    "receipt_statuses": [
      "accepted",
      "running",
      "succeeded",
      "failed",
      "cancelled",
      "unknown"
    ]
  }
}
